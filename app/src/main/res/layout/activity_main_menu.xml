<?xml version="1.0" encoding="utf-8"?>
<!-- 主菜单布局 - 六个功能入口 + 顶部工具栏 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="@dimen/spacing_medium">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_small">

        <TextView
            android:id="@+id/tvAge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="年龄段：2-3岁"
            android:textSize="@dimen/text_medium"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:padding="@dimen/spacing_small" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 0"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:padding="@dimen/spacing_small" />

        <Button
            android:id="@+id/btnSound"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="🔊"
            android:textSize="28sp"
            android:background="@drawable/bg_card"
            android:layout_marginStart="@dimen/spacing_small" />

        <Button
            android:id="@+id/btnChangeAge"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="切换"
            android:textSize="@dimen/text_medium"
            android:textStyle="bold"
            android:background="@drawable/bg_card"
            android:layout_marginStart="@dimen/spacing_small" />

        <Button
            android:id="@+id/btnParent"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="⚙️"
            android:textSize="28sp"
            android:background="@drawable/bg_card"
            android:layout_marginStart="@dimen/spacing_small" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/welcome"
        android:textSize="@dimen/text_title"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:padding="@dimen/spacing_medium" />

    <!-- 主菜单按钮网格 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="@dimen/spacing_medium"
            android:layout_gravity="center">

            <!-- 数字 -->
            <Button
                android:id="@+id/btnNumbers"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:text="🔢\n数字"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

            <!-- 字母 -->
            <Button
                android:id="@+id/btnLetters"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:backgroundTint="@color/secondary"
                android:text="🔤\n字母"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

            <!-- 颜色 -->
            <Button
                android:id="@+id/btnColors"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:backgroundTint="@color/accent"
                android:text="🎨\n颜色"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

            <!-- 形状 -->
            <Button
                android:id="@+id/btnShapes"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:backgroundTint="@color/yellow"
                android:text="🔷\n形状"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

            <!-- 游戏 -->
            <Button
                android:id="@+id/btnGames"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:backgroundTint="@color/green"
                android:text="🎮\n游戏"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

            <!-- 奖励 -->
            <Button
                android:id="@+id/btnRewards"
                android:layout_width="0dp"
                android:layout_height="@dimen/menu_card_size"
                android:layout_columnWeight="1"
                android:layout_rowWeight="1"
                android:layout_margin="@dimen/spacing_small"
                android:background="@drawable/bg_learn_card"
                android:backgroundTint="@color/purple"
                android:text="🏆\n我的奖励"
                android:textSize="@dimen/text_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textAllCaps="false" />

        </GridLayout>
    </ScrollView>
</LinearLayout>
