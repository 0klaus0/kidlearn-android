<?xml version="1.0" encoding="utf-8"?>
<!-- 年龄选择界面布局 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/spacing_large">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="@dimen/spacing_huge" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_age"
            android:textSize="@dimen/text_large"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_huge" />

        <!-- 装饰图标 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎨 📚 🎮"
            android:textSize="56sp"
            android:layout_marginBottom="@dimen/spacing_large" />

        <!-- 年龄按钮 1 -->
        <Button
            android:id="@+id/btnAge23"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_large_height"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:background="@drawable/bg_age_button"
            android:textColor="@color/text_primary"
            android:padding="@dimen/spacing_medium"
            android:textAllCaps="false"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="2-3 岁\n基础认知" />

        <!-- 年龄按钮 2 -->
        <Button
            android:id="@+id/btnAge45"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_large_height"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:background="@drawable/bg_age_button"
            android:textColor="@color/text_primary"
            android:padding="@dimen/spacing_medium"
            android:textAllCaps="false"
            android:layout_marginBottom="@dimen/spacing_medium"
            android:text="4-5 岁\n进阶学习" />

        <!-- 年龄按钮 3 -->
        <Button
            android:id="@+id/btnAge56"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_large_height"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:background="@drawable/bg_age_button"
            android:textColor="@color/text_primary"
            android:padding="@dimen/spacing_medium"
            android:textAllCaps="false"
            android:layout_marginBottom="@dimen/spacing_huge"
            android:text="5-6 岁\n全面挑战" />

        <!-- 确认按钮 -->
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="wrap_content"
            android:minWidth="240dp"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/confirm"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:background="@drawable/bg_age_button_selected"
            android:textColor="@color/text_primary"
            android:textAllCaps="false"
            android:paddingHorizontal="@dimen/spacing_huge" />

    </LinearLayout>
</ScrollView>
