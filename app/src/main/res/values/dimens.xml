<?xml version="1.0" encoding="utf-8"?>
<!-- 尺寸配置：按钮、字体等尺寸符合幼儿操作特点 -->
<resources>

    <!-- 按钮尺寸：按钮直径建议不小于60dp -->
    <dimen name="button_min_width">80dp</dimen>
    <dimen name="button_min_height">80dp</dimen>
    <dimen name="button_large_width">120dp</dimen>
    <dimen name="button_large_height">120dp</dimen>
    <dimen name="button_round_corner">24dp</dimen>

    <!-- 主菜单图标尺寸 -->
    <dimen name="menu_icon_size">100dp</dimen>
    <dimen name="menu_card_size">160dp</dimen>

    <!-- 学习内容卡片 -->
    <dimen name="learn_card_size">140dp</dimen>
    <dimen name="learn_card_text">36sp</dimen>

    <!-- 字体大小：幼儿友好 -->
    <dimen name="text_title">32sp</dimen>
    <dimen name="text_large">28sp</dimen>
    <dimen name="text_medium">22sp</dimen>
    <dimen name="text_regular">18sp</dimen>
    <dimen name="text_small">14sp</dimen>

    <!-- 间距 -->
    <dimen name="spacing_tiny">4dp</dimen>
    <dimen name="spacing_small">8dp</dimen>
    <dimen name="spacing_medium">16dp</dimen>
    <dimen name="spacing_large">24dp</dimen>
    <dimen name="spacing_huge">32dp</dimen>

    <!-- 圆角 -->
    <dimen name="corner_small">8dp</dimen>
    <dimen name="corner_medium">16dp</dimen>
    <dimen name="corner_large">32dp</dimen>
    <dimen name="corner_circle">9999dp</dimen>

    <!-- 游戏元素尺寸 -->
    <dimen name="game_item_size">100dp</dimen>
    <dimen name="game_tile_size">80dp</dimen>

    <!-- 奖励星星尺寸 -->
    <dimen name="star_size">48dp</dimen>
    <dimen name="sticker_size">72dp</dimen>

    <!-- 顶部导航 -->
    <dimen name="top_bar_height">72dp</dimen>

    <!-- 动画持续时间 -->
    <integer name="anim_short">200</integer>
    <integer name="anim_medium">400</integer>
    <integer name="anim_long">800</integer>

</resources>
